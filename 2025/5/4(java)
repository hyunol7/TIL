practice10

문제 설명 : 1번 부터 N번 까지의 풍선이 원형으로 놓여있고, N번 풍선 오른쪽에는 i+1번 풍선이 있고, 왼쪽에는 i-1번 풍선이 있다.
단, 1번 풍선의 왼쪽에 N번 풍선이 있고, N번 풍선의 오른쪽에는 1번 풍선이 있다.
각 풍선 아네는 종이가 하나 들어있고, 종이에는 -N보다 크거나 같고, N보다작건 같은 정수가 하나 적혀있다.
이 풍선들을 다음과 같은 규칙으로 터트린다.

우선, 제일 처음에는 1번 풍선을 터트린다.
다음에는 풍선 안에 있는 종이를 꺼내어 그 종이에 적혀있는 값만큼 이동 하여 다음 풍선을 터뜨린다.
양수가 적혀 있을 경우에는 오른쪽으로, 음수가 적혀있을 때는 왼쪽으로 이동하며, 이동할 때에는, 이미 터진 풍선은 빼고 이동을 ㅎ나다.

예를 들어 다섯 개의 풍선 안에 차례로 3,2,1,-3,-1이 적혀 있었다고 한다면
5개의 풍선 안에 차례로 3,2,1,-3,-1이 적혀있을 때, 3이 적혀있는 1번 풍선, -3이 적혀있는 4번 풍선, -1이 적혀 있는 5번 풍선, 1이 적혀 있는 3번 풍선, 2가 적혀 있는 2번 풍선의 순서대로 터지게 하는 코드 작성

package org.example.practice;

// 풍선을 나타내는 노드 클래스
class Node {
    int data;       // 풍선 번호
    int cmd;        // 풍선 안에 적힌 이동 명령 값
    boolean visited; // 풍선이 터졌는지 여부
    Node next;      // 다음 노드(오른쪽)
    Node prev;      // 이전 노드(왼쪽)

    // 생성자
    public Node(int data, int cmd, boolean visited, Node next, Node prev) {
        this.data = data;
        this.cmd = cmd;
        this.visited = visited;
        this.next = next;
        this.prev = prev;
    }
}

// 풍선들을 원형으로 연결하는 리스트 클래스
class LikedList {
    Node head;

    // 풍선을 리스트에 추가하는 메서드
    public void add(int data, int cmd) {
        if (this.head == null) {
            // 리스트가 비어있다면 첫 노드를 만들고 양방향 순환 연결
            this.head = new Node(data, cmd, false, null, null);
            this.head.next = this.head;
            this.head.prev = this.head;
        } else {
            // 이미 노드가 있다면, 마지막 노드 기준으로 새 노드를 만들어 연결
            Node tail = this.head.prev;
            Node newNode = new Node(data, cmd, false, this.head, tail);
            tail.next = newNode;
            this.head.prev = newNode;
        }
    }
}

public class practice10 {
    // 풍선 터트리기 로직을 수행하는 메서드
    public static void solution(int[] data) {
        LikedList list = new LikedList();

        // 풍선 리스트 생성
        for (int i = 0; i < data.length; i++) {
            list.add(i + 1, data[i]); // 풍선 번호는 1부터 시작
        }

        Node cur = list.head; // 현재 노드를 1번 풍선으로 시작
        int visitCnt = 0;     // 터진 풍선 수
        int cmd = cur.cmd;    // 현재 명령값(초기엔 1번 풍선의 값)
        cur.visited = true;   // 첫 풍선 터트림
        System.out.print(cur.data + " ");
        visitCnt++;

        while (visitCnt < data.length) {
            int move = cmd;

            // 풍선 이동
            while (true) {
                if (move > 0) {
                    cur = cur.next;
                    if (!cur.visited) move--;
                } else if (move < 0) {
                    cur = cur.prev;
                    if (!cur.visited) move++;
                }

                if (move == 0 && !cur.visited) break;
            }

            // 터트릴 풍선 출력
            System.out.print(cur.data + " ");
            cur.visited = true;
            visitCnt++;
            cmd = cur.cmd; // 다음 이동 명령
        }
    }

    public static void main(String[] args) {
        int[] balloon = {3, 2, 1, -3, -1}; // 예제 1
        solution(balloon);               // 결과: 1 4 5 3 2

        System.out.println();

        balloon = new int[]{3, 2, -1, -2}; // 예제 2
        solution(balloon);               // 결과 확인
    }
}
